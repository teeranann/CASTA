    given-names: Teeranan
    email: teeranan.no@buu.ac.th
    affiliation: "Department of Chemistry, Faculty of Science, Burapha University, Chonburi, Thailand"
repository-code: "https://github.com/teeranann/CASTA"
url: "https://github.com/teeranann/CASTA"
license-url: "https://polyformproject.org/licenses/noncommercial/1.0.0"
keywords:
  - contact angle
  - surface tension
  - drop shape analysis
  - sessile drop
  - pendant drop
  - wettability
  - image analysis
date-released: "2026-06-05"
